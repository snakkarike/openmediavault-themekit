{
    "type": "config",
    "id": "conf.service.themekit",
    "title": "ThemeKit",
    "queryinfo": {
        "xpath": "//services/themekit",
        "iterable": false
    },
    "properties": {
        "theme": {
            "type": "string",
            "enum": [
                "none",
                "default",
                "alucard",
                "black-gold-theme",
                "butterfly-theme",
                "catppuccin-frappe",
                "catppuccin-latte",
                "catppuccin-macchiato",
                "catppuccin-mocha",
                "okabe-ito",
                "dracula",
                "gruvbox-dark",
                "gruvbox-light",
                "high-contrast-light",
                "Ilavenil",
                "matrix-theme",
                "miami-beach",
                "nord-theme",
                "Notion-Dark-Mode",
                "rose-pine",
                "rose-pine-dawn",
                "rose-pine-moon",
                "shades-of-coffee",
                "shades-of-gray",
                "simple-dark",
                "1970-theme",
                "thyrium",
                "YNA-Theme-Dark",
                "YNA-Theme-Light",
                "you-need-a-dark-mode",
                "theme-zero-dark"
            ],
            "default": "default"
        },
        "accent": {
            "type": "string",
            "enum": [
                "default",
                "slate",
                "gray",
                "zinc",
                "neutral",
                "stone",
                "red",
                "orange",
                "amber",
                "yellow",
                "lime",
                "green",
                "emerald",
                "teal",
                "cyan",
                "sky",
                "blue",
                "indigo",
                "violet",
                "purple",
                "fuchsia",
                "pink",
                "rose"
            ],
            "default": "default"
        },
        "accentSpecialPages": {
            "type": "boolean",
            "default": false
        },
        "enableTypography": {
            "type": "boolean",
            "default": false
        },
        "enableCustomCss": {
            "type": "boolean",
            "default": false
        },
        "baseFontSize": {
            "type": "integer",
            "minimum": 10,
            "maximum": 24,
            "default": 16
        },
        "customFont": {
            "type": "string",
            "default": ""
        },
        "customCss": {
            "type": "string",
            "default": ""
        },
        "fontCategory": {
            "type": "string",
            "default": "all"
        },
        "customFont_all": {
            "type": "string",
            "default": ""
        },
        "customFont_sans_serif": {
            "type": "string",
            "default": ""
        },
        "customFont_serif": {
            "type": "string",
            "default": ""
        },
        "customFont_display": {
            "type": "string",
            "default": ""
        },
        "customFont_handwriting": {
            "type": "string",
            "default": ""
        },
        "customFont_monospace": {
            "type": "string",
            "default": ""
        }
    }
}