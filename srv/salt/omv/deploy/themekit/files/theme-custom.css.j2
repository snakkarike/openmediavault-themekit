/* Datatable Accent */
omv-datatable .action-toolbar .mat-toolbar .mat-button:not(.mat-button-disabled),
.omv-dark-theme .mat-toolbar .mat-icon-button:not(.mat-button-disabled) {
  color: var(--theme-primary) !important;
}

omv-datatable .ngx-datatable:not(.cell-selection) .datatable-body-row:hover,
omv-datatable .ngx-datatable:not(.cell-selection) .datatable-body-row:hover .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable:not(.cell-selection) .datatable-body-row:hover,
.omv-dark-theme omv-datatable .ngx-datatable:not(.cell-selection) .datatable-body-row:hover .datatable-row-group
{
  background-color: var(--color-tableBorderHover, var(--color-tableRowBackgroundHover, var(--theme-primary))) !important;
  color: var(--color-tableTextHover, inherit) !important;
}

omv-datatable .ngx-datatable .datatable-body-row.datatable-row-odd:hover,
omv-datatable .ngx-datatable .datatable-body-row.datatable-row-odd:hover .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable .datatable-body-row.datatable-row-odd:hover,
.omv-dark-theme omv-datatable .ngx-datatable .datatable-body-row.datatable-row-odd:hover .datatable-row-group {
  background-color: var(--color-tableBorderHover, var(--color-tableRowBackgroundHover, var(--theme-primary))) !important;
  color: var(--color-tableTextHover, inherit) !important;
}

omv-datatable .ngx-datatable .datatable-body-row.datatable-row-even:hover,
omv-datatable .ngx-datatable .datatable-body-row.datatable-row-even:hover .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable .datatable-body-row.datatable-row-even:hover,
.omv-dark-theme omv-datatable .ngx-datatable .datatable-body-row.datatable-row-even:hover .datatable-row-group {
  background-color: var(--color-tableBorderHover, var(--color-tableRowBackgroundHover, var(--theme-primary))) !important;
  color: var(--color-tableTextHover, inherit) !important;
}

/* Logo Inversion for lighter themes */
.omv-navigation-bar .header .logo {
  filter: var(--logo-filter, none) !important;
}

/* Base Menu Item styles */
.mat-menu-item {
  background: var(--color-menuItemBackground, transparent) !important;
  color: var(--color-menuItemText, inherit) !important;
}

.omv-dark-theme .mat-menu-item,
.mat-menu-item.omv-dark-theme {
  background: transparent !important;
  color: var(--color-menuItemText, #fff) !important;
}

/* Base Option Item styles */
.mat-option {
  background: transparent !important;
  color: var(--color-menuItemText, inherit) !important;
}

.omv-dark-theme .mat-option,
.mat-option.omv-dark-theme {
  background: transparent !important;
  color: var(--color-menuItemText, #fff) !important;
}

/* Fix menu item icon colors */
.mat-menu-item .mat-icon-no-color,
.mat-menu-submenu-icon,
.omv-dark-theme .mat-menu-item .mat-icon-no-color,
.omv-dark-theme .mat-menu-submenu-icon {
  color: inherit !important;
}

/* Menu Accent */
.mat-menu-item:hover {
  border-left: .25rem solid var(--theme-primary) !important;
}

.mat-menu-item.active {
  border-left: .25rem solid var(--theme-primary) !important;
}

.omv-dark-theme .mat-menu-item:hover {
  border-left: .25rem solid var(--theme-primary) !important;
}

.omv-dark-theme .mat-menu-item.active {
  border-left: .25rem solid var(--theme-primary) !important;
}

/* List Accent */
.mat-list-item.active {
  border-left: 3px solid var(--theme-primary) !important;
}

.mat-list-item:hover:not(.active) {
  border-left: 3px solid var(--theme-primary) !important;
}

/* Sidebar Active/Hover Item Background */
.mat-drawer .mat-list-item:hover,
.mat-drawer .mat-list-item.active,
.omv-dark-theme .mat-drawer .mat-list-item:hover,
.omv-dark-theme .mat-drawer .mat-list-item.active {
  background-color: var(--color-sidebarItemBackgroundHover, var(--color-menuItemBackgroundHover, var(--color-tableRowBackgroundHover, rgba(0, 0, 0, 0.04)))) !important;
}

/* Info card accent */
.mat-card.alert-info {
    color: #fff !important;
    background-color: var(--theme-primary) !important;
}

.alert-info {
    background-color: var(--theme-primary) !important;
    color: white !important;
}

/* Force cursor color */
.mat-select-trigger .mat-select-value,
.mat-select-trigger input.mat-select-placeholder {
    color: var(--theme-primary) !important;
}

/* Force icon color inside selection */
.mat-select-trigger .mat-select-arrow {
    color: var(--theme-primary) !important;
}

/* Fix disabled text color */
.mat-select.mat-disabled .mat-select-value {
    color: rgba(0,0,0,0.26) !important;
}

/* Force focus border color */
.mat-select.mat-form-field-has-label.mat-focused .mat-form-field-outline-thick {
    color: var(--theme-primary) !important;
}

/* Adjust opacity */
.mat-select.mat-form-field-has-label.mat-focused .mat-form-field-outline-thick .mat-form-field-outline-start,
.mat-select.mat-form-field-has-label.mat-focused .mat-form-field-outline-thick .mat-form-field-outline-end {
    border-color: var(--theme-primary) !important;
}

{% if theme != 'default' %}
/* Fix form field labels and icons contrast when light/dark mismatch */
.mat-form-field-appearance-legacy .mat-form-field-label, 
.mat-form-field-appearance-legacy .mat-hint,
.mat-form-field-label, 
.mat-hint {
    color: var(--color-pageText, inherit) !important;
}

.mat-form-field-prefix .mat-icon,
.mat-form-field-suffix .mat-icon,
.omv-dark-theme .mat-form-field-prefix .mat-icon,
.omv-dark-theme .mat-form-field-suffix .mat-icon {
    color: var(--color-pageText, inherit) !important;
}

.mat-form-field-appearance-legacy .mat-form-field-underline {
    background-color: var(--color-pageText, inherit) !important;
    opacity: 0.42 !important;
}

/* Fix generic dividers and checkboxes to adapt to custom theme text color */
.mat-divider, .omv-dark-theme .mat-divider {
    border-top-color: var(--color-pageText, inherit) !important;
    opacity: 0.12 !important;
}

.mat-checkbox-frame, .omv-dark-theme .mat-checkbox-frame {
    border-color: var(--color-pageText, inherit) !important;
    opacity: 0.54 !important;
}

/* Fix disabled buttons contrast */
.mat-icon-button.mat-button-disabled.mat-button-disabled, 
.omv-dark-theme .mat-icon-button.mat-button-disabled.mat-button-disabled,
.mat-button.mat-button-disabled.mat-button-disabled, 
.omv-dark-theme .mat-button.mat-button-disabled.mat-button-disabled {
    color: var(--color-pageText, inherit) !important;
    opacity: 0.26 !important;
}

/* Aggressively override mat-toolbar background and text to respect custom themes */
.mat-toolbar {
    background-color: var(--color-sidebarBackground, var(--mat-background-color-body, #222e36)) !important;
    color: var(--color-sidebarItemText, var(--color-pageText, #fff)) !important;
}

/* Aggressively override mat-card background to respect custom themes */
.mat-card, .omv-dark-theme .mat-card {
    background-color: var(--color-pillBackground, var(--color-cardBackground, var(--color-pageBackground, #fff))) !important;
    color: var(--color-pillText, var(--color-pageText, inherit)) !important;
}

/* Override datatable active/selected row */
omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active,
omv-datatable .ngx-datatable.single-selection .datatable-body-row.active,
omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active .datatable-row-group,
omv-datatable .ngx-datatable.single-selection .datatable-body-row.active .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active,
.omv-dark-theme omv-datatable .ngx-datatable.single-selection .datatable-body-row.active,
.omv-dark-theme omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable.single-selection .datatable-body-row.active .datatable-row-group,
omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active:hover,
omv-datatable .ngx-datatable.single-selection .datatable-body-row.active:hover,
omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active:hover .datatable-row-group,
omv-datatable .ngx-datatable.single-selection .datatable-body-row.active:hover .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active:hover,
.omv-dark-theme omv-datatable .ngx-datatable.single-selection .datatable-body-row.active:hover,
.omv-dark-theme omv-datatable .ngx-datatable.multi-selection .datatable-body-row.active:hover .datatable-row-group,
.omv-dark-theme omv-datatable .ngx-datatable.single-selection .datatable-body-row.active:hover .datatable-row-group {
    background-color: var(--color-tableRowBackgroundHighlight, var(--color-tableBorderSelected, var(--theme-primary))) !important;
    color: var(--color-tableRowBackgroundHighlightText, var(--color-tableTextSelected, #fff)) !important;
}

/* Override form selection (dropdowns) active/hover background */
.mat-option:hover:not(.mat-option-disabled),
.mat-option.mat-active:not(.mat-option-disabled),
.mat-option:focus:not(.mat-option-disabled),
.omv-dark-theme .mat-option:hover:not(.mat-option-disabled),
.omv-dark-theme .mat-option.mat-active:not(.mat-option-disabled),
.omv-dark-theme .mat-option:focus:not(.mat-option-disabled) {
    background-color: var(--color-formInputBackgroundSelected, var(--color-menuItemBackgroundHover, var(--color-tableRowBackgroundHover))) !important;
    color: var(--color-formInputTextSelected, var(--color-pageText, inherit)) !important;
}
{% endif %}

{% if accentSpecialPages | default(false) %}
/* Use accent color for Login, Authentication, Shutdown and Standby pages by disabling the wallpaper */
.background {
    display: none !important;
    background-image: none !important;
}
{% endif %}

/* Apply a darker theme accent to the topbar on special pages */
.topbar {
    background-color: color-mix(in srgb, var(--theme-primary) 80%, black) !important;
}

{% endif %}
